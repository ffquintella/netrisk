<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:GUIClient.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:GUIClient.Views"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="500"
        xmlns:dvm="clr-namespace:GUIClient.ViewModels" x:DataType="dvm:MainWindowViewModel" x:Class="GUIClient.Views.MainWindow"
        Opened="LoadCheckAsync"
        Icon="/Assets/NetRisk.ico"
        Title="NetRisk Application"
        Name="MWindow"
        Width="1024" Height="768"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="Full"
        TransparencyLevelHint="Mica, AcrylicBlur, Transparent, None"
        TransparencyBackgroundFallback="#282928"
        Background="Transparent"
>
    
    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <!-- macOS Global Menu Redirection:
         On Apple Darwin this NativeMenu is hoisted into the system global menu bar
         automatically; on Windows/Linux it is ignored and the in-window Menu below
         (which is collapsed on macOS via IsNotMacOS) is shown instead. -->
    <NativeMenu.Menu>
        <NativeMenu>
            <NativeMenuItem Header="{Binding StrApplicationMn}">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="{Binding StrAbout}" Command="{Binding OnMenuAboutCommand}"/>
                        <NativeMenuItemSeparator/>
                        <NativeMenuItem Header="{Binding StrExitMn}" Command="{Binding OnMenuExitCommand}"/>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>
            <NativeMenuItem Header="{Binding StrDebug}" IsVisible="{Binding IsDebug}">
                <NativeMenuItem.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="IRP - Create"
                                        Command="{Binding BtDebugWindowClicked}" CommandParameter="IRP-Create"/>
                        <NativeMenuItem Header="IRP Task - Create"
                                        Command="{Binding BtDebugWindowClicked}" CommandParameter="IRP-Task-Create"/>
                    </NativeMenu>
                </NativeMenuItem.Menu>
            </NativeMenuItem>
        </NativeMenu>
    </NativeMenu.Menu>

    <!-- Global hot-keys (active app-wide). Per-view/per-dialog gestures
         (Ctrl+S, Ctrl+F, Esc) are bound in their respective views. -->
    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+P" Command="{Binding HotKeyOpenReportsCommand}"/>
    </Window.KeyBindings>

    <Window.Styles>
        <Style Selector="WindowDrawnDecorations /template/ Panel#PART_TitleTextPanel > TextBlock">
            <Setter Property="IsVisible" Value="False" />
        </Style>
    </Window.Styles>

    <Panel>
        <ExperimentalAcrylicBorder IsHitTestVisible="False" Name="AcrylicBorderCtrl">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    TintColor="Black"
                    TintOpacity="1"
                    MaterialOpacity="0.65" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <Grid RowDefinitions="Auto, *">
            <!-- Custom Title Bar Container -->
            <Grid Grid.Row="0" RowDefinitions="Auto, Auto" Background="Transparent" WindowDecorationProperties.ElementRole="TitleBar">
                <!-- In-window Menu: hidden on macOS where it is replaced by the global menu bar -->
                <Menu Grid.Row="0" Margin="{Binding AppMenuMargin}" HorizontalAlignment="Left"
                      IsVisible="{Binding IsNotMacOS}" WindowDecorationProperties.ElementRole="User">
                    <MenuItem Header="{Binding StrApplicationMn}">
                        <MenuItem Header="{Binding StrAbout}"
                                  Command="{Binding OnMenuAboutCommand}"/>
                        <MenuItem Header="{Binding StrExitMn}"
                                  Command="{Binding OnMenuExitCommand}"/>
                    </MenuItem>
                    <MenuItem Header="{Binding StrDebug}" IsVisible="{Binding IsDebug}">
                        <MenuItem Header="IRP - Create"
                                  Command="{Binding BtDebugWindowClicked}" CommandParameter="IRP-Create"/>
                        <MenuItem Header="IRP Task - Create"
                                  Command="{Binding BtDebugWindowClicked}" CommandParameter="IRP-Task-Create"/>
                    </MenuItem>
                </Menu>

                <!-- Navigation Bar -->
                <!-- NavigationBar carries its own DataContext (NavigationBarViewModel), so the
                     inset must be bound against the MainWindow's DataContext explicitly; a bare
                     {Binding NavBarMargin} would resolve against the wrong VM and fall back to 0,
                     leaving the notification bell under the macOS traffic-light controls. -->
                <views:NavigationBar Grid.Row="1"
                                     ParentWindow="{Binding ElementName=MWindow}"
                                     Margin="{Binding #MWindow.((dvm:MainWindowViewModel)DataContext).NavBarMargin}"
                                     WindowDecorationProperties.ElementRole="User"/>
            </Grid>
            
            <Grid Name="OverlayGridCtrl" Grid.Row="1" />

            <!-- Content area -->
            <Grid Grid.Row="1">
                <views:DashboardView IsVisible="{Binding $parent.DataContext.ViewDashboardIsVisible}" />
                <views:HostsView Margin="10"
                                 IsVisible="{Binding $parent.DataContext.HostsIsVisible}" />
                <views:AssessmentView Margin="10"
                                       ParentWindow="{Binding ElementName=MWindow}"
                                       IsVisible="{Binding $parent.DataContext.AssessmentIsVisible}" />
                <views:RiskView Margin="10"
                                IsVisible="{Binding $parent.DataContext.RiskIsVisible}" />
                <views:EntitiesView Margin="10"
                                    IsVisible="{Binding $parent.DataContext.EntitiesIsVisible}" />
                <views:VulnerabilitiesView Margin="10" DataContext="{Binding VulnerabilitiesViewModel}"
                                           IsVisible="{Binding $parent.DataContext.VulnerabilitiesIsVisible}" />
                <views:IncidentsView Margin="10"
                                     DataContext="{Binding IncidentsViewModel}"
                                     IsVisible="{Binding #MWindow.DataContext.IncidentsIsVisble}"/>
            </Grid>
        </Grid>
    </Panel>

</Window>
