<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:GUIClient.ViewModels.Reports"
        xmlns:entities="clr-namespace:DAL.Entities;assembly=DAL"
        xmlns:converters="clr-namespace:GUIClient.Converters"
        xmlns:material="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        Width="800" Height="450"
        x:Class="GUIClient.Views.Reports.ReportTemplateManagerWindow"
        x:DataType="vm:ReportTemplateManagerViewModel"
        Title="Report Template Manager">

    <Design.DataContext>
        <vm:ReportTemplateManagerViewModel/>
    </Design.DataContext>

    <Window.Resources>
        <converters:DateToFormatedStringConverter x:Key="DateToFormatedStringConverter"/>
    </Window.Resources>

    <Grid RowDefinitions="Auto, *, Auto">

        <TextBlock Grid.Row="0" Text="Report Template Manager" Classes="header"/>

        <!-- Master / detail -->
        <Grid Grid.Row="1" ColumnDefinitions="300, 3, *">

            <Grid Grid.Column="0" RowDefinitions="Auto, *, Auto">
                <TextBlock Grid.Row="0" Text="Templates" Classes="header2"/>
                <ListBox Grid.Row="1"
                         SelectionMode="Single"
                         ItemsSource="{Binding Templates}"
                         SelectedItem="{Binding SelectedTemplate}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="entities:ReportTemplate">
                            <StackPanel Margin="0 2">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding Description}"
                                           FontSize="11" Foreground="#9a9a9a"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Control bar -->
                <Grid Grid.Row="2" ColumnDefinitions="Auto,Auto,*,Auto">
                    <Button Grid.Column="0" Name="BtAdd" Classes="subButton"
                            ToolTip.Tip="Create"
                            Command="{Binding CreateCommand}">
                        <material:MaterialIcon Kind="Add"/>
                    </Button>
                    <Button Grid.Column="1" Name="BtEdit" Classes="subButton type2"
                            ToolTip.Tip="Update"
                            Command="{Binding UpdateCommand}">
                        <material:MaterialIcon Kind="Pencil"/>
                    </Button>
                    <Button Grid.Column="3" Name="BtDelete" Classes="subButton type3"
                            ToolTip.Tip="Delete"
                            Command="{Binding DeleteCommand}">
                        <material:MaterialIcon Kind="Delete"/>
                    </Button>
                </Grid>
            </Grid>

            <GridSplitter Grid.Column="1"/>

            <ScrollViewer Grid.Column="2">
                <Grid RowDefinitions="Auto,*" IsVisible="{Binding !!SelectedTemplate}">
                    <TextBlock Grid.Row="0" Text="Details" Classes="header2"/>
                    <Grid Grid.Row="1" ColumnDefinitions="Auto, *" RowDefinitions="Auto,Auto,Auto,Auto"
                          ColumnSpacing="5" Margin="0 5 0 0">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" Classes="form_label"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedTemplate.Name}" Classes="form_text2"/>

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Description" Classes="form_label"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedTemplate.Description}" Classes="form_long_text"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Created" Classes="form_label"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedTemplate.CreatedAt, Converter={StaticResource DateToFormatedStringConverter}}" Classes="form_text2"/>

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Last updated" Classes="form_label"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedTemplate.UpdatedAt, Converter={StaticResource DateToFormatedStringConverter}}" Classes="form_text2"/>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <TextBlock Grid.Row="2" Text="Report Template Manager" Classes="footer"/>
    </Grid>
</Window>
