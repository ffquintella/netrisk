<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:GUIClient.ViewModels"
        xmlns:reports="clr-namespace:GUIClient.ViewModels.Reports"
        xmlns:avalonia="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="250"
        Width="400" Height="250"
        xmlns:dvm="clr-namespace:GUIClient.ViewModels.Reports" x:DataType="dvm:CreateReportDialogViewModel" x:Class="GUIClient.Views.Reports.CreateReportDialog"
        Name="WinCreateReportDialog"
        Title="CreateReportDialog">

    <Design.DataContext>
        <reports:CreateReportDialogViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0" Text="{Binding StrCreateReport}" TextAlignment="Center" Classes="header"/>

        <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock Text="{Binding StrReportType}"/>
            <ComboBox MinWidth="250" MaxDropDownHeight="200"
                      ItemsSource="{Binding ReportOptions}"
                      SelectedItem="{Binding SelectedReportOption, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                    <DataTemplate x:DataType="dvm:ReportTypeOption">
                        <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Classes="dialog1" Margin="10" IsDefault="True" Command="{Binding CreateReport}">
                <StackPanel Orientation="Horizontal">
                    <avalonia:MaterialIcon Kind="Check" Margin="10 0"/>
                    <TextBlock Text="{Binding StrCreate}" Margin="0 0 10 0"/>
                </StackPanel>
            </Button>
            <Button Classes="dialog2" Margin="10" Command="{Binding Cancel}">
                <StackPanel Orientation="Horizontal">
                    <avalonia:MaterialIcon Kind="Cancel" Margin="10 0"/>
                    <TextBlock Text="{Binding StrCancel}" Margin="0 0 10 0"/>
                </StackPanel>
            </Button>
        </StackPanel>

    </Grid>
</Window>
