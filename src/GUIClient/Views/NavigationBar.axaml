<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:vm="using:GUIClient.ViewModels"
             xmlns:converters="clr-namespace:GUIClient.Converters"
             xmlns:views="clr-namespace:GUIClient.Views"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:dvm="clr-namespace:GUIClient.ViewModels" x:DataType="dvm:NavigationBarViewModel" x:Class="GUIClient.Views.NavigationBar"
             Name="NavigationUserControl">
    
    <Design.DataContext>
        <vm:NavigationBarViewModel/>
    </Design.DataContext>
    
    <UserControl.Resources>
        <converters:HasPermissionConverter x:Key="HasPermissionConverter"/>
        <converters:AuthenticatedUserHasPermissionConverter x:Key="AuthenticatedUserHasPermissionConverter"/>
    </UserControl.Resources>
    
    <Grid ColumnDefinitions="Auto, *, Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
            <Border ToolTip.Tip="{Binding StrNotifications}" Classes="tooltip">
                <Badge BadgePosition="Right" BadgeContent="{Binding NotificationCount}" FontSize="6">
                    <Button Name="BtnBell" Classes="nav-base nav-notification"
                            Command="{Binding BtNotificationsClicked}"
                            CommandParameter="{Binding $parent[views:MainWindow]}">
                        <Panel Width="20" Height="20">
                            <material:MaterialIcon Kind="Bell" Width="20" Height="20" Foreground="OrangeRed" IsVisible="{Binding HasUnreadNotifications}"/>
                            <material:MaterialIcon Kind="Bell" Width="20" Height="20" Foreground="WhiteSmoke" IsVisible="{Binding !HasUnreadNotifications}"/>
                        </Panel>
                    </Button>
                </Badge>
            </Border>
        </StackPanel>
        <Rectangle Grid.Column="1" />
        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Border ToolTip.Tip="{Binding StrDashboard}" Classes="tooltip">
                <Button Name="BtnDashboard" Classes="nav-base nav-icon"
                        Command="{Binding BtDashboardClicked}"
                        CommandParameter="{Binding $parent[views:MainWindow]}">
                    <material:MaterialIcon Kind="Home" Width="20" Height="20"/>
                </Button>
            </Border>
            <Border ToolTip.Tip="{Binding StrAssessment}" Classes="tooltip" IsVisible="True">
                <Button Name="BtnAssessment" Classes="nav-base nav-icon"
                        IsEnabled="{Binding HasAssessmentPermission}"
                        Command="{Binding BtAssessmentClicked}"
                        CommandParameter="{Binding $parent[views:MainWindow]}">
                    <material:MaterialIcon Kind="ClipboardCheckMultipleOutline" Width="20" Height="20"/>
                </Button>
            </Border>
            <Border ToolTip.Tip="{Binding StrEntities}" Classes="tooltip">
                <Button Name="BtnEntities" Classes="nav-base nav-icon"
                        IsEnabled="{Binding HasEntitiesPermission}"
                        Command="{Binding BtEntitiesClicked}"
                        CommandParameter="{Binding $parent[views:MainWindow]}">
                    <material:MaterialIcon Kind="Company" Width="20" Height="20"/>
                </Button>
            </Border>
            <Border ToolTip.Tip="{Binding StrRisks}" Classes="tooltip">
                <Button Name="BtnRisk" Classes="nav-base nav-icon"
                        IsEnabled="{Binding HasRiskPermission}"
                        Command="{Binding BtRiskClicked}"
                        CommandParameter="{Binding $parent[views:MainWindow]}">
                    <material:MaterialIcon Kind="Alert" Width="20" Height="20"/>
                </Button>
            </Border>
            <Border ToolTip.Tip="{Binding StrVulnerabilities}" Classes="tooltip">
                <Button Name="BtnVulnerability" Classes="nav-base nav-icon"
                        IsEnabled="{Binding AuthenticatedUserInfo, 
                            Converter={StaticResource AuthenticatedUserHasPermissionConverter}, ConverterParameter=vulnerabilities}"
                        Command="{Binding BtVulnerabilityClicked}"
                        CommandParameter="{Binding $parent[views:MainWindow]}">
                    <material:MaterialIcon Kind="ShieldBug" Width="20" Height="20"/>
                </Button>
            </Border>
            <Border ToolTip.Tip="{Binding StrIncidents}" Classes="tooltip">
                <Button Name="BtnIncident" Classes="nav-base nav-icon"
                        IsEnabled="{Binding AuthenticatedUserInfo, 
                            Converter={StaticResource AuthenticatedUserHasPermissionConverter}, ConverterParameter=incident_management}"
                        Command="{Binding BtIncidentsClicked}"
                        CommandParameter="{Binding $parent[views:MainWindow]}">
                    <material:MaterialIcon Kind="AlertOctagram" Width="20" Height="20"/>
                </Button>
            </Border>
            <Border ToolTip.Tip="{Binding StrReports}" Classes="tooltip">
                <Button Name="BtnReports" Classes="nav-base nav-icon"
                        IsEnabled="{Binding HasReportsPermission}"
                        Command="{Binding BtReportsClicked}"
                        CommandParameter="{Binding $parent[views:MainWindow]}">
                    <material:MaterialIcon Kind="MonitorDashboard" Width="20" Height="20"/>
                </Button>
            </Border>
            <Border ToolTip.Tip="{Binding StrDevices}" Classes="tooltip">
                <Button Name="BtnDevice" Classes="nav-base nav-icon"
                        IsEnabled="{Binding HasHostsPermission}"
                        Command="{Binding BtDeviceClicked}"
                        CommandParameter="{Binding $parent[views:MainWindow]}">
                    <material:MaterialIcon Kind="Laptop" Width="20" Height="20"/>
                </Button>
            </Border>
            <Border ToolTip.Tip="{Binding StrSettings}" Classes="tooltip">
                <Button Name="BtnSettings" Classes="nav-base nav-icon"
                        IsEnabled="{Binding IsAdmin}"
                        Command="{Binding BtSettingsClicked}"
                        CommandParameter="{Binding $parent[views:MainWindow]}">
                    <material:MaterialIcon Kind="Settings" Width="20" Height="20"/>
                </Button>
            </Border>
            <Button Name="BtnAccount" Classes="nav-base nav-account"
                    IsEnabled="{Binding IsEnabled}"
                    Command="{Binding BtAccountClicked}"
                    CommandParameter="{Binding $parent[views:MainWindow]}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <material:MaterialIcon Kind="AccountCircle" Width="20" Height="20"/>
                    <TextBlock Text="{Binding LoggedUser}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
