<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:GUIClient.ViewModels"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:convertes="clr-namespace:GUIClient.Converters"
        xmlns:sys="using:System"
        mc:Ignorable="d" d:DesignWidth="820" d:DesignHeight="560"
        xmlns:dvm="clr-namespace:GUIClient.ViewModels" x:DataType="dvm:AssessmentQuestionViewModel" x:Class="GUIClient.Views.AssessmentQuestionView"
        Title="Assessment Question"
        Width="820" Height="560"
        MinWidth="640" MinHeight="420"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True"
        WindowDecorations="Full">
    
    <Design.DataContext>
        <vm:AssessmentQuestionViewModel/>
    </Design.DataContext>
    
    <Window.Resources>
        <convertes:ByteToStringConverter x:Key="byteToStringConverter"/>
    </Window.Resources>
    
    <Panel>
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial
                    BackgroundSource="Digger"
                    TintColor="Black"
                    TintOpacity="1"
                    MaterialOpacity="0.65" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>
        
        <Panel Margin="20 40 20 20">
            <Grid RowDefinitions="Auto, Auto, Auto, *" ColumnDefinitions="*">
                <TextBlock Grid.Row="0" Grid.Column="0"
                           HorizontalAlignment="Center"
                           Margin="0 0 0 4"
                           Text="{Binding StrQuestion}"/>

                <TextBox Grid.Row="1" Grid.Column="0" Margin="0 0 0 10"
                         Height="50"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         HorizontalAlignment="Stretch"
                         Text="{Binding TxtQuestion}"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0 0 0 6"
                           HorizontalAlignment="Center"
                           Text="{Binding StrAnswers}"/>

                <Grid Grid.Row="3" RowDefinitions="Auto,*,Auto">
                    <!-- ANSWER EDIT ROW -->
                    <Grid Grid.Row="0" ColumnDefinitions="220,Auto,*,Auto" Margin="0 0 0 8">
                        <StackPanel Grid.Column="0" Margin="0 0 10 0">
                            <TextBlock Text="{Binding StrAnswer}"
                                       HorizontalAlignment="Left"/>
                            <TextBox IsEnabled="{Binding InputEnabled}"
                                     HorizontalAlignment="Stretch"
                                     Text="{Binding TxtAnswer}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0 0 10 0">
                            <TextBlock Text="{Binding StrRisk}"
                                       HorizontalAlignment="Left"/>
                            <NumericUpDown Value="{Binding TxtRisk}"
                                           IsEnabled="{Binding InputEnabled}"
                                           Increment="1" Minimum="0" Maximum="10"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="0 0 10 0">
                            <TextBlock Text="{Binding StrSubject}"
                                       HorizontalAlignment="Left"/>
                            <TextBox IsEnabled="{Binding InputEnabled}"
                                     HorizontalAlignment="Stretch"
                                     Text="{Binding TxtSubject}"/>
                        </StackPanel>
                        <!-- ANSWERS Buttons -->
                        <StackPanel Grid.Column="3" Orientation="Horizontal"
                                    VerticalAlignment="Bottom">
                            <Button Name="BtAddAnswer" Classes="operation" Margin="3"
                                    ToolTip.Tip="{Binding StrAddAnswerTip}"
                                    IsEnabled="{Binding !InputEnabled}"
                                    Command="{Binding BtAddAnswerClicked}">
                                <material:MaterialIcon Kind="Add"/>
                            </Button>
                            <Button Name="BtCancelAddAnswer" Classes="operation" Margin="3"
                                    ToolTip.Tip="{Binding StrCancelAnswerTip}"
                                    Command="{Binding BtCancelAddAnswerClicked}"
                                    IsEnabled="{Binding InputEnabled}">
                                <material:MaterialIcon Kind="Cancel"/>
                            </Button>
                            <Button Name="BtSaveAnswer" Classes="operation" Margin="3"
                                    ToolTip.Tip="{Binding StrConfirmAnswerTip}"
                                    IsEnabled="{Binding BtSaveEnabled}"
                                    Command="{Binding BtSaveAnswerClicked}"
                                    CommandParameter="{Binding SelectedAnswer,
                                    Converter={x:Static ObjectConverters.IsNotNull}}"
                                    >
                                <material:MaterialIcon Kind="Check"/>
                            </Button>
                            <Button Name="BtDeleteAnswer" Classes="operation type3" Margin="3"
                                    ToolTip.Tip="{Binding StrDeleteAnswerTip}"
                                    IsEnabled="{Binding !!SelectedAnswer}"
                                    Command="{Binding BtDeleteAnswerClicked}"
                                    >
                                <material:MaterialIcon Kind="Delete"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                    <!-- ANSWERS DATA GRID -->
                    <DataGrid Grid.Row="1" Name="AnswersDataGrid"
                              IsEnabled="{Binding GridEnabled}"
                              SelectedItem="{Binding SelectedAnswer}"
                              ItemsSource="{Binding  Answers, Mode=OneWay}"
                              AutoGenerateColumns="False">
                        <DataGrid.Columns >
                            <DataGridTextColumn IsReadOnly="True" 
                                                Header="ID" 
                                                Binding="{Binding Id}"/>
                            <DataGridTextColumn IsReadOnly="True" 
                                                Header="{Binding StrAnswer}" 
                                                Binding="{Binding Answer}"/>
                            <DataGridTextColumn IsReadOnly="True" 
                                                Header="Score" 
                                                Binding="{Binding RiskScore}"/>
                            <DataGridTextColumn IsReadOnly="True" 
                                                Header="{Binding StrSubject}" 
                                                Binding="{Binding RiskSubject, 
                                    Converter={StaticResource byteToStringConverter}}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <!-- Main Buttons -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="0 10 0 0">
                        <Button Name="BtSaveQuestion" Classes="dialog1" Margin="3"
                                ToolTip.Tip="{Binding StrSaveQuestionTip}"
                                Command="{Binding BtSaveQuestionClicked}">
                            <StackPanel Orientation="Horizontal">
                                <material:MaterialIcon Kind="ContentSave" Margin="0 0 5 0"/>
                                <TextBlock Text="{Binding StrSave}"/>
                            </StackPanel>
                        </Button>
                        <Button Name="BtCancelSaveQestion" Classes="dialog2" Margin="3"
                                ToolTip.Tip="{Binding StrCancelQuestionTip}"
                                Command="{Binding BtCancelSaveQuestionClicked}">
                            <StackPanel Orientation="Horizontal">
                                <material:MaterialIcon Kind="Cancel" Margin="0 0 5 0"/>
                                <TextBlock Text="{Binding StrCancel}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Grid>
        </Panel>
        
        <!-- Draggable TitleBar Helper -->
        <Grid Height="30" VerticalAlignment="Top" Background="Transparent" WindowDecorationProperties.ElementRole="TitleBar" />
    </Panel>
</Window>
