# Using docker-puppet image
FROM ffquintella/docker-puppet:9.8.24

# Maintained by ffquintella
LABEL maintainer="ffquintella"

LABEL version="{{VERSION}}"

# Make necessary directories
RUN mkdir -p /netrisk
RUN mkdir -p /var/log/netrisk

RUN ln -s /opt/puppetlabs/bin/puppet /usr/bin/puppet

# COPY NETRISK API
# Ownership is set at copy time (uid/gid 7070 == the puppet 'netrisk' user) so we
# never re-chown the payload in a second layer. Recursively re-owning large files
# (e.g. the 177 MB OpenFaceONNX.dll) duplicates them into another layer and trips
# the overlayfs/containerd snapshotter during image export.
COPY --chown=7070:7070 api /netrisk

# COPY NETRISK API CONFIG TO DEFAULTS DIRECTORY
RUN mkdir -p /netrisk/defaults
COPY --chown=7070:7070 api/appsettings.json /netrisk/defaults
COPY --chown=7070:7070 api/ClientInformation.yaml /netrisk/defaults
COPY --chown=7070:7070 api/EntitiesConfiguration.yaml /netrisk/defaults
COPY --chown=7070:7070 api/Scripts /netrisk/defaults/Scripts
COPY --chown=7070:7070 api/EmailTemplates /netrisk/defaults/EmailTemplates

# ENABLE LEGACY OPENSSL
RUN update-crypto-policies --set LEGACY

# CREATE CONFIGURATION DIRECTORY
RUN mkdir -p /configurations

# COPY PUPPET MANIFESTS
RUN  mkdir /etc/puppet/ ; mkdir /etc/puppet/manifests ; mkdir /etc/puppet/modules ; mkdir /opt/scripts
COPY puppet-api /etc/puppet/manifests
COPY puppet-modules /etc/puppet/modules

# Executing puppet install script
RUN /usr/bin/puppet apply --modulepath=/etc/puppet/modules /etc/puppet/manifests/install.pp ; \
    rm -rf /tmp/* ; rm -rf /var/cache/* ; rm -rf /var/tmp/* ; rm -rf /var/opt/staging

EXPOSE 5443

# Create the start script and set permissions
COPY entrypoint-api.sh /entrypoint.sh
# Strip any CR characters (defense against a CRLF checkout on the build host)
# and make executable, so the `#!/bin/bash` shebang always execs cleanly.
RUN sed -i 's/\r$//' /entrypoint.sh && chmod 755 /entrypoint.sh

# Data to save
VOLUME /netrisk/EmailTemplates
VOLUME /netrisk/Scripts

# VAIRABLES
ENV FACTER_SERVER_HTTPS_PORT=5443

# Setting up entrypoint
ENTRYPOINT [ "/entrypoint.sh" ]